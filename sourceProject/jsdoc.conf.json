{
    "plugins": [],
    "recurseDepth": 10,
    "source": {
        "include":[
            "source/"
        ],
        "includePattern": ".+\\.(m)?js(doc|x)?$",
        "excludePattern": "(^|\\/|\\\\)_"
    },
    "sourceType": "module",
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": ["jsdoc","closure"]
    },
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false
    },
    "define": {
        "window":{}
    }
}